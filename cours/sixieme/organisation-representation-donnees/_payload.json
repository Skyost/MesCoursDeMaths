[{"data":1,"prerenderedAt":32},["Reactive",2],{"/cours/sixieme/organisation-representation-donnees/":3,"current-commit-sha":20},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"_id":8,"body":9,"id":10,"name":11,"page-title":11,"page-title-search":12,"number":13,"level":5,"pdf":14,"linked-resources":15,"title":16,"_source":17,"_file":18,"_extension":19},"/latex/sixieme/organisation-representation-donnees-cours","sixieme",false,"","content:latex:sixieme:organisation-representation-donnees-cours.tex","\u003Cdiv class=\"doctitle\">\n\u003Cp>Organisation et représentation des données\u003C/p>\n\u003C/div>\n\u003Cdiv class=\"docnumber\">\n\u003Cp>13\u003C/p>\n\u003C/div>\n\u003Cdiv class=\"bubble-objectifs\">\n\u003Cul>\n\u003Cli>\u003Cp>Prélever des données numériques à partir de supports variés.\nProduire des tableaux, diagrammes et graphiques organisant des données\nnumériques.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Exploiter et communiquer des résultats de mesures.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Savoir lire, exploiter et construire des représentations usuelles\n: tableaux (en deux ou plusieurs colonnes, à double entrée) ; diagrammes\nen bâtons, circulaires ou semi-circulaires ; graphiques\ncartésiens.\u003C/p>\u003C/li>\n\u003C/ul>\n\u003C/div>\n\u003Ch2>Organisation de données\u003C/h2>\n\u003Ch3>Tableaux simples\u003C/h3>\n\u003Csection class=\"bubble-retenir\">\n\u003Ch4>Définitions\u003C/h4>\n\u003Cp>Les tableaux permettent d’\u003Cstrong>organiser\u003C/strong> et de\n\u003Cstrong>regrouper\u003C/strong> des données pour les lire plus facilement. On\npeut représenter les données en ligne ou en colonne. Pour organiser des\ndonnées selon \u003Cstrong>un seul type\u003C/strong> d’information, on utilise\ndes tableaux simples (aussi appelés \u003Cq>tableaux à une seule\nentrée\u003C/q>).\u003C/p>\n\u003C/section>\n\u003Csection class=\"bubble-exercice\">\n\n\u003Cdiv class=\"row\">\n\n\u003Cdiv class=\"col-12 col-lg-6\">\n\u003Cp>Ci-contre se trouve le nombre de voix obtenues par trois candidats\naux élections des délégués.\u003C/p>\n\u003Col>\n\u003Cli>\u003Cp>Combien de voix a obtenu Inès ? \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Qui a obtenu \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">13\u003C/span>\u003C/span>\u003C/span>\u003C/span> voix ? \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/div>\n\u003Cdiv class=\"col-12 col-lg-6\">\n\u003Cdiv class=\"text-end\">\n\u003Ctable>\n\u003Cthead>\n\u003Ctr class=\"header\">\n\u003Cth style=\"text-align: left;\">\u003Cstrong>Candidat\u003C/strong>\u003C/th>\n\u003Cth style=\"text-align: center;\">Zoé\u003C/th>\n\u003Cth style=\"text-align: center;\">Axel\u003C/th>\n\u003Cth style=\"text-align: center;\">Inès\u003C/th>\n\u003C/tr>\n\u003C/thead>\n\u003Ctbody>\n\u003Ctr class=\"odd\">\n\u003Ctd style=\"text-align: left;\">\u003Cstrong>Nombre de voix\u003C/strong>\u003C/td>\n\u003Ctd style=\"text-align: center;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">8\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: center;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">13\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: center;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">7\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003C/tr>\n\u003C/tbody>\n\u003C/table>\n\u003C/div>\n\u003C/div>\n\u003C/div>\n\u003C/section>\n\u003Csection class=\"bubble-correction\">\n\n\u003Col>\n\u003Cli>\u003Cp>Inès a obtenu \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">7\u003C/span>\u003C/span>\u003C/span>\u003C/span> voix.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>C’est Axel qui a obtenu \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">13\u003C/span>\u003C/span>\u003C/span>\u003C/span> voix.\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/section>\n\u003Ch3>Tableaux à double entrée\u003C/h3>\n\u003Csection class=\"bubble-retenir\">\n\u003Ch4>Définition\u003C/h4>\n\u003Cp>Un tableau à double entrée permet d’organiser des données selon\n\u003Cstrong>deux types\u003C/strong> d’information mises en relation. Les\ntableurs peuvent être utiles pour réaliser de tels tableaux\ninformatiquement.\u003C/p>\n\u003C/section>\n\u003Csection class=\"bubble-exercice\">\n\n\u003Cp>Le professeur d’EPS a regroupé dans le tableau ci-dessous le nombre\nd’élèves inscrits à l’UNSS par sport pour les classes de 6e et de\n5e.\u003C/p>\n\u003Cdiv class=\"row\">\n\n\u003Cdiv class=\"col-12 col-lg-6\">\n\u003Col>\n\u003Cli>\u003Cp>Combien d’élèves sont inscrits en gym ? \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003Cbr>\n\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Combien d’élèves de 6e sont inscrits en natation ? \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003Cbr>\n\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/div>\n\u003Cdiv class=\"col-12 col-lg-6\">\n\u003Cdiv class=\"text-end\">\n\u003Ctable>\n\u003Cthead>\n\u003Ctr class=\"header\">\n\u003Cth style=\"text-align: left;\">\u003C/th>\n\u003Cth style=\"text-align: left;\">\u003Cstrong>Natation\u003C/strong>\u003C/th>\n\u003Cth style=\"text-align: left;\">\u003Cstrong>Gymnastique\u003C/strong>\u003C/th>\n\u003Cth style=\"text-align: left;\">\u003Cstrong>Badminton\u003C/strong>\u003C/th>\n\u003C/tr>\n\u003C/thead>\n\u003Ctbody>\n\u003Ctr class=\"odd\">\n\u003Ctd style=\"text-align: left;\">\u003Cstrong>Nombre de 6e\u003C/strong>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">3\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">6\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">2\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003C/tr>\n\u003Ctr class=\"even\">\n\u003Ctd style=\"text-align: left;\">\u003Cstrong>Nombre de 5e\u003C/strong>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">5\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">4\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">6\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003C/tr>\n\u003C/tbody>\n\u003C/table>\n\u003C/div>\n\u003C/div>\n\u003C/div>\n\u003C/section>\n\u003Csection class=\"bubble-correction\">\n\n\u003Col>\n\u003Cli>\u003Cp>Il y a \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.7278em;vertical-align:-0.0833em;\">\u003C/span>\u003Cspan class=\"mord\">6\u003C/span>\u003Cspan class=\"mspace\" style=\"margin-right:0.2222em;\">\u003C/span>\u003Cspan class=\"mbin\">+\u003C/span>\u003Cspan class=\"mspace\" style=\"margin-right:0.2222em;\">\u003C/span>\u003C/span>\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">4\u003C/span>\u003Cspan class=\"mspace\" style=\"margin-right:0.2778em;\">\u003C/span>\u003Cspan class=\"mrel\">=\u003C/span>\u003Cspan class=\"mspace\" style=\"margin-right:0.2778em;\">\u003C/span>\u003C/span>\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">10\u003C/span>\u003C/span>\u003C/span>\u003C/span> élèves inscrits en\ngymnastique.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Il y a \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">3\u003C/span>\u003C/span>\u003C/span>\u003C/span> élèves de 6e inscrits en\nnatation.\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/section>\n\u003Ch2>Représentation de données\u003C/h2>\n\u003Ch3>Diagrammes en bâtons\u003C/h3>\n\u003Csection class=\"bubble-retenir\">\n\u003Ch4>Définition\u003C/h4>\n\u003Cp>Un \u003Cstrong>diagramme en bâtons\u003C/strong> permet de comparer\nvisuellement des données.\u003C/p>\n\u003C/section>\n\u003Csection class=\"bubble-exercice\">\n\n\u003Cdiv class=\"row\">\n\n\u003Cdiv class=\"col\" style=\"--column-size: 0.67;\">\n\u003Cp>On a représenté graphiquement ci-contre le nombre de cousin(es) de\nLéa en fonction de leur âge.\u003C/p>\n\u003Col>\n\u003Cli>\u003Cp>Combien Léa a-t-elle de cousin(es) qui ont \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">10\u003C/span>\u003C/span>\u003C/span>\u003C/span>\nans ? \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003Cbr>\n\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Quel âge ont le plus grand nombre de cousin(es) de Léa ? \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003Cbr>\n\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/div>\n\u003Cdiv class=\"col\" style=\"--column-size: 0.32999999999999996;\">\n\u003Cdiv class=\"text-end\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/organisation-representation-donnees-cours/tikzpicture-1.svg\" alt=\"tikzpicture-1\">\u003C/p>\n\u003C/div>\n\u003C/div>\n\u003C/div>\n\u003C/section>\n\u003Csection class=\"bubble-correction\">\n\n\u003Col>\n\u003Cli>\u003Cp>Léa \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">2\u003C/span>\u003C/span>\u003C/span>\u003C/span> cousin(es) qui ont \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">10\u003C/span>\u003C/span>\u003C/span>\u003C/span> ans.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Le plus grand nombre de cousin(es) de Léa ont \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">2\u003C/span>\u003C/span>\u003C/span>\u003C/span> ans.\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/section>\n\u003Ch3>Diagrammes circulaires / en camembert\u003C/h3>\n\u003Csection class=\"bubble-retenir\">\n\u003Ch4>Définition\u003C/h4>\n\u003Cp>Un \u003Cstrong>diagramme circulaire\u003C/strong> (ou semi-circulaires)\npermettent de mettre en évidence la répartition de données suivant\nplusieurs catégories.\u003C/p>\n\u003C/section>\n\u003Csection class=\"bubble-exercice\">\n\n\u003Cdiv class=\"row\">\n\n\u003Cdiv class=\"col\" style=\"--column-size: 0.65;\">\n\u003Cp>On a représenté graphiquement ci-contre la répartition de garçons et\nde filles parmi les cousin(es) de Léa.\u003C/p>\n\u003Cp>Quelle est la proportion de filles parmi les cousins de Léa ? \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003Cbr>\n\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\n\u003C/div>\n\u003Cdiv class=\"col\" style=\"--column-size: 0.35;\">\n\u003Cdiv class=\"text-end\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/organisation-representation-donnees-cours/tikzpicture-2.svg\" alt=\"tikzpicture-2\">\u003C/p>\n\u003C/div>\n\u003C/div>\n\u003C/div>\n\u003C/section>\n\u003Csection class=\"bubble-correction\">\n\n\u003Cp>Léa a \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:1.1901em;vertical-align:-0.345em;\">\u003C/span>\u003Cspan class=\"mord\">\u003Cspan class=\"mopen nulldelimiter\">\u003C/span>\u003Cspan class=\"mfrac\">\u003Cspan class=\"vlist-t vlist-t2\">\u003Cspan class=\"vlist-r\">\u003Cspan class=\"vlist\" style=\"height:0.8451em;\">\u003Cspan style=\"top:-2.655em;\">\u003Cspan class=\"pstrut\" style=\"height:3em;\">\u003C/span>\u003Cspan class=\"sizing reset-size6 size3 mtight\">\u003Cspan class=\"mord mtight\">\u003Cspan class=\"mord mtight\">6\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003Cspan style=\"top:-3.23em;\">\u003Cspan class=\"pstrut\" style=\"height:3em;\">\u003C/span>\u003Cspan class=\"frac-line\" style=\"border-bottom-width:0.04em;\">\u003C/span>\u003C/span>\u003Cspan style=\"top:-3.394em;\">\u003Cspan class=\"pstrut\" style=\"height:3em;\">\u003C/span>\u003Cspan class=\"sizing reset-size6 size3 mtight\">\u003Cspan class=\"mord mtight\">\u003Cspan class=\"mord mtight\">5\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003Cspan class=\"vlist-s\">​\u003C/span>\u003C/span>\u003Cspan class=\"vlist-r\">\u003Cspan class=\"vlist\" style=\"height:0.345em;\">\u003Cspan>\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003Cspan class=\"mclose nulldelimiter\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/span> de filles parmi ses cousins et\ncousines.\u003C/p>\n\u003C/section>\n\u003Ch3>Graphique cartésien\u003C/h3>\n\u003Csection class=\"bubble-retenir\">\n\u003Ch4>Définition\u003C/h4>\n\u003Cp>Un \u003Cstrong>graphique cartésien\u003C/strong> permet de montrer\nvisuellement l’évolution d’une grandeur en fonction d’une autre. Ce type\nde graphique est souvent utilisé pour étudier l’évolution d’une grandeur\ndans le temps.\u003C/p>\n\u003C/section>\n\u003Csection class=\"bubble-exercice\">\n\n\u003Cdiv class=\"row\">\n\n\u003Cdiv class=\"col\" style=\"--column-size: 0.58;\">\n\u003Cp>On a représenté graphiquement ci-contre l’évolution de la taille d’un\ndes cousins de Léa en fonction de son âge.\u003C/p>\n\u003Col>\n\u003Cli>\u003Cp>Quel taille faisait-il à \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">1\u003C/span>\u003C/span>\u003C/span>\u003C/span> an ? \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003Cbr>\n\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>À quel âge mesurait-il \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">95\u003C/span>\u003C/span>\u003C/span>\u003C/span> cm ? \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003Cbr>\n\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/div>\n\u003Cdiv class=\"col\" style=\"--column-size: 0.42000000000000004;\">\n\u003Cdiv class=\"text-end\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/organisation-representation-donnees-cours/tikzpicture-3.svg\" alt=\"tikzpicture-3\">\u003C/p>\n\u003C/div>\n\u003C/div>\n\u003C/div>\n\u003C/section>\n\u003Csection class=\"bubble-correction\">\n\n\u003Col>\n\u003Cli>\u003Cp>Le cousin de Léa mesurait \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">80\u003C/span>\u003C/span>\u003C/span>\u003C/span> cm à \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">1\u003C/span>\u003C/span>\u003C/span>\u003C/span> an.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Le cousin de Léa mesurait \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">95\u003C/span>\u003C/span>\u003C/span>\u003C/span> cm à \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">4\u003C/span>\u003C/span>\u003C/span>\u003C/span> ans.\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/section>\n\u003Ch2>Production\u003C/h2>\n\u003Csection class=\"bubble-retenir\">\n\u003Ch4>Propriétés\u003C/h4>\n\u003Cul>\n\u003Cli>\u003Cp>Dans un diagramme en bâtons, les hauteurs des bâtons sont\nproportionnelles aux valeurs qu’elles représentent.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Dans un diagramme circulaire, les mesures des angles sont\nproportionnelles aux valeurs qu’elles représentent.\u003C/p>\u003C/li>\n\u003C/ul>\n\u003C/section>\n\u003Csection class=\"bubble-exercice\">\n\n\u003Cp>Le professeur d’arts plastiques a recensé la couleur préférée de\nchacun de ses \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">24\u003C/span>\u003C/span>\u003C/span>\u003C/span> élèves. Il a organisé ses résultats\ndans le tableau de proportionnalité suivant, et a ajouté une ligne pour\npréparer la réalisation d’un diagramme circulaire.\u003C/p>\n\u003Cdiv class=\"text-center\">\n\u003Ctable>\n\u003Cthead>\n\u003Ctr class=\"header\">\n\u003Cth style=\"text-align: left;\">\u003Cstrong>Couleur préférée\u003C/strong>\u003C/th>\n\u003Cth style=\"text-align: left;\">Vert\u003C/th>\n\u003Cth style=\"text-align: left;\">Rose\u003C/th>\n\u003Cth style=\"text-align: left;\">Bleu\u003C/th>\n\u003Cth style=\"text-align: left;\">\u003Cem>Total\u003C/em>\u003C/th>\n\u003C/tr>\n\u003C/thead>\n\u003Ctbody>\n\u003Ctr class=\"odd\">\n\u003Ctd style=\"text-align: left;\">\u003Cstrong>Nombre d’élèves\u003C/strong>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">8\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">4\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">12\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.8389em;vertical-align:-0.1944em;\">\u003C/span>\u003Cspan class=\"mord\">\u003Cspan class=\"mord mathit\">24\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003C/tr>\n\u003Ctr class=\"even\">\n\u003Ctd style=\"text-align: left;\">\u003Cstrong>Mesure de l’angle (en\n°)\u003C/strong>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">\u003Cspan class=\"mord mathit\">360\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003C/tr>\n\u003C/tbody>\n\u003C/table>\n\u003C/div>\n\u003Col>\n\u003Cli>\u003Cp>Compléter le tableau ci-dessus pour qu’il soit de\nproportionnalité.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>En l’utilisant, compléter les diagrammes en bâtons et circulaires\nsuivants.\u003C/p>\n\u003Cdiv class=\"text-center\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/organisation-representation-donnees-cours/tikzpicture-4.svg\" alt=\"tikzpicture-4\">\u003C/p>\n\u003C/div>\u003C/li>\n\u003C/ol>\n\u003C/section>\n\u003Csection class=\"bubble-correction\">\n\n\u003Col>\n\u003Cli>\u003Cp>Voici le tableau complété :\u003C/p>\n\u003Cdiv class=\"text-center\">\n\u003Ctable>\n\u003Cthead>\n\u003Ctr class=\"header\">\n\u003Cth style=\"text-align: left;\">\u003Cstrong>Couleur préférée\u003C/strong>\u003C/th>\n\u003Cth style=\"text-align: left;\">Vert\u003C/th>\n\u003Cth style=\"text-align: left;\">Rose\u003C/th>\n\u003Cth style=\"text-align: left;\">Bleu\u003C/th>\n\u003Cth style=\"text-align: left;\">\u003Cem>Total\u003C/em>\u003C/th>\n\u003C/tr>\n\u003C/thead>\n\u003Ctbody>\n\u003Ctr class=\"odd\">\n\u003Ctd style=\"text-align: left;\">\u003Cstrong>Nombre d’élèves\u003C/strong>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">8\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">4\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">12\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.8389em;vertical-align:-0.1944em;\">\u003C/span>\u003Cspan class=\"mord\">\u003Cspan class=\"mord mathit\">24\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003C/tr>\n\u003Ctr class=\"even\">\n\u003Ctd style=\"text-align: left;\">\u003Cstrong>Mesure de l’angle (en\n°)\u003C/strong>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">120\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">60\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">180\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">\u003Cspan class=\"mord mathit\">360\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003C/tr>\n\u003C/tbody>\n\u003C/table>\n\u003C/div>\u003C/li>\n\u003Cli>\u003Cp>Et voici les diagrammes complétés :\u003C/p>\n\u003Cdiv class=\"text-center\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/organisation-representation-donnees-cours/tikzpicture-5.svg\" alt=\"tikzpicture-5\">\u003C/p>\n\u003C/div>\u003C/li>\n\u003C/ol>\n\u003C/section>\n\u003Csection class=\"bubble-retenir\">\n\u003Ch4>Méthode\u003C/h4>\n\u003Cp>Pour représenter une grandeur \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6833em;\">\u003C/span>\u003Cspan class=\"mord mathnormal\" style=\"margin-right:0.05017em;\">B\u003C/span>\u003C/span>\u003C/span>\u003C/span> en fonction d’une\ngrandeur \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6833em;\">\u003C/span>\u003Cspan class=\"mord mathnormal\">A\u003C/span>\u003C/span>\u003C/span>\u003C/span> dans un graphique cartésien, on place\n:\u003C/p>\n\u003Cul>\n\u003Cli>\u003Cp>Sur l’axe horizontal, appelé \u003Cstrong>axe des abscisses\u003C/strong>,\nles valeurs de la grandeur \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6833em;\">\u003C/span>\u003Cspan class=\"mord mathnormal\">A\u003C/span>\u003C/span>\u003C/span>\u003C/span>.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Sur l’axe vertical, appelé \u003Cstrong>axe des ordonnées\u003C/strong>,\nles valeurs de la grandeur \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6833em;\">\u003C/span>\u003Cspan class=\"mord mathnormal\" style=\"margin-right:0.05017em;\">B\u003C/span>\u003C/span>\u003C/span>\u003C/span>.\u003C/p>\u003C/li>\n\u003C/ul>\n\u003C/section>\n\u003Csection class=\"bubble-exercice\">\n\n\u003Cp>Voici un relevé météorologique des températures de Boissy Saint-Léger\ndu 10 janvier 2023.\u003C/p>\n\u003Cdiv class=\"text-center\">\n\u003Ctable>\n\u003Cthead>\n\u003Ctr class=\"header\">\n\u003Cth style=\"text-align: left;\">\u003Cstrong>Heure\u003C/strong>\u003C/th>\n\u003Cth style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">0\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/th>\n\u003Cth style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">3\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/th>\n\u003Cth style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">6\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/th>\n\u003Cth style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">9\u003C/span>\u