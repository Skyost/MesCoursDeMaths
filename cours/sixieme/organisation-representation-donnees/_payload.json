Search":102,"number":103,"pdf":104},"longueur-perimetre","Longueur et périmètre","longueur et perimetre",6,"/pdf/sixieme/longueur-perimetre.pdf",{"id":106,"name":107,"pageTitle":107,"pageTitleSearch":106,"number":108,"pdf":109},"division","Division",7,"/pdf/sixieme/division.pdf",{"id":111,"name":112,"pageTitle":112,"pageTitleSearch":111,"number":113,"pdf":114},"angles","Angles",8,"/pdf/sixieme/angles.pdf",{"id":116,"name":117,"pageTitle":117,"pageTitleSearch":116,"number":118,"pdf":119},"fractions","Fractions",9,"/pdf/sixieme/fractions.pdf",{"id":121,"name":122,"pageTitle":122,"pageTitleSearch":121,"number":123,"pdf":124},"aires","Aires",10,"/pdf/sixieme/aires.pdf",{"id":126,"name":127,"pageTitle":127,"pageTitleSearch":126,"number":128,"pdf":129},"proportionnalite","Proportionnalité",11,"/pdf/sixieme/proportionnalite.pdf",{"id":131,"name":132,"pageTitle":132,"pageTitleSearch":133,"number":134,"pdf":135},"symetrie-axiale","Symétrie axiale","symetrie axiale",12,"/pdf/sixieme/symetrie-axiale.pdf",{"id":137,"name":138,"pageTitle":138,"pageTitleSearch":139,"number":140,"pdf":141},"organisation-representation-donnees","Organisation et représentation des données","organisation et representation des donnees",13,"/pdf/sixieme/organisation-representation-donnees.pdf",{"id":143,"name":144,"pageTitle":144,"pageTitleSearch":143,"number":145,"pdf":146},"solides","Solides",14,"/pdf/sixieme/solides.pdf",{"id":148,"name":149,"pageTitle":149,"pageTitleSearch":150,"number":151,"pdf":152},"reperage-deplacement","Repérage et déplacement","reperage et deplacement",15,"/pdf/sixieme/reperage-deplacement.pdf",{"dataRepository":154,"websiteRepository":157},{"long":155,"short":156},"a47bbc3e19c1a546e05eeeb40953a4b2e2e1804d","a47bbc3",{"long":158,"short":159},"dffca300a32eaab3f5a57aa662b773c4e36731c3","dffca30",{"id":137,"body":161,"name":138,"pageTitle":138,"pageTitleSearch":139,"number":140,"pdf":141,"linkedResources":162},"\n\n\u003Cdiv class=\"bubble-objectives\">\n\u003Cul>\n\u003Cli>\u003Cp>Prélever des données numériques à partir de supports variés.\nProduire des tableaux, diagrammes et graphiques organisant des données\nnumériques.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Exploiter et communiquer des résultats de mesures.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Savoir lire, exploiter et construire des représentations usuelles\n: tableaux (en deux ou plusieurs colonnes, à double entrée) ; diagrammes\nen bâtons, circulaires ou semi-circulaires ; graphiques\ncartésiens.\u003C/p>\u003C/li>\n\u003C/ul>\n\u003C/div>\n\u003Ch2>Organisation de données\u003C/h2>\n\u003Ch3>Tableaux simples\u003C/h3>\n\u003Csection class=\"bubble-remember\">\n\u003Ch4>Définition\u003C/h4>\n\u003Cp>Les \u003Cstrong>tableaux\u003C/strong> permettent d’organiser et de regrouper\ndes données pour les lire plus facilement. On peut représenter les\ndonnées en ligne ou en colonne. Pour organiser des données selon un seul\ntype d’information, on utilise des \u003Cstrong>tableaux simples\u003C/strong> (on\nparle aussi de \u003Cstrong>tableaux à une seule entrée\u003C/strong>).\u003C/p>\n\u003C/section>\n\u003Csection class=\"bubble-exercise\">\n\n\u003Cp>Ci-contre se trouve le nombre de voix obtenues par trois candidats\naux élections des délégués.\u003C/p>\n\u003Cdiv class=\"text-center\">\n\u003Ctable>\n\u003Cthead>\n\u003Ctr>\n\u003Cth style=\"text-align: left;\">\u003Cstrong>Candidat\u003C/strong>\u003C/th>\n\u003Cth style=\"text-align: center;\">Zoé\u003C/th>\n\u003Cth style=\"text-align: center;\">Axel\u003C/th>\n\u003Cth style=\"text-align: center;\">Inès\u003C/th>\n\u003C/tr>\n\u003C/thead>\n\u003Ctbody>\n\u003Ctr>\n\u003Ctd style=\"text-align: left;\">\u003Cstrong>Nombre de voix\u003C/strong>\u003C/td>\n\u003Ctd style=\"text-align: center;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">8\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: center;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">13\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: center;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">7\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003C/tr>\n\u003C/tbody>\n\u003C/table>\n\u003C/div>\n\u003Col>\n\u003Cli>\u003Cp>Combien de voix a obtenu Inès ? \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dotline\">\u003C/span>\u003Cspan class=\"mord\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Qui a obtenu \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">13\u003C/span>\u003C/span>\u003C/span>\u003C/span> voix ? \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dotline\">\u003C/span>\u003Cspan class=\"mord\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/section>\n\u003Csection class=\"bubble-correction\">\n\n\u003Col>\n\u003Cli>\u003Cp>Inès a obtenu \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">7\u003C/span>\u003C/span>\u003C/span>\u003C/span> voix.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>C’est Axel qui a obtenu \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">13\u003C/span>\u003C/span>\u003C/span>\u003C/span> voix.\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/section>\n\u003Ch3>Tableaux à double entrée\u003C/h3>\n\u003Csection class=\"bubble-remember\">\n\u003Ch4>Définition\u003C/h4>\n\u003Cp>Un \u003Cstrong>tableau à double entrée\u003C/strong> permet d’organiser des\ndonnées selon deux types d’information mises en relation. Les tableurs\npeuvent être utiles pour opérer informatiquement sur de tels\ntableaux.\u003C/p>\n\u003C/section>\n\u003Csection class=\"bubble-exercise\">\n\n\u003Cp>Le professeur d’EPS a regroupé dans le tableau ci-dessous le nombre\nd’élèves inscrits à l’UNSS par sport pour les classes de 6ème et de\n5ème.\u003C/p>\n\u003Cdiv class=\"text-center\">\n\u003Ctable>\n\u003Cthead>\n\u003Ctr>\n\u003Cth style=\"text-align: left;\">\u003C/th>\n\u003Cth style=\"text-align: left;\">\u003Cstrong>Natation\u003C/strong>\u003C/th>\n\u003Cth style=\"text-align: left;\">\u003Cstrong>Gym\u003C/strong>\u003C/th>\n\u003Cth style=\"text-align: left;\">\u003Cstrong>Badminton\u003C/strong>\u003C/th>\n\u003C/tr>\n\u003C/thead>\n\u003Ctbody>\n\u003Ctr>\n\u003Ctd style=\"text-align: left;\">\u003Cstrong>Nombre de 6ème\u003C/strong>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">3\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">6\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">2\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003C/tr>\n\u003Ctr>\n\u003Ctd style=\"text-align: left;\">\u003Cstrong>Nombre de 5ème\u003C/strong>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">5\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">4\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">6\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003C/tr>\n\u003C/tbody>\n\u003C/table>\n\u003C/div>\n\u003Col>\n\u003Cli>\u003Cp>Combien d’élèves sont inscrits en gym ? \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dotline\">\u003C/span>\u003Cspan class=\"mord\">\u003C/span>\u003C/span>\u003C/span>\u003C/span> \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dotline\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Combien d’élèves de 6ème sont inscrits en natation ? \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dotline\">\u003C/span>\u003Cspan class=\"mord\">\u003C/span>\u003C/span>\u003C/span>\u003C/span> \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dotline\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/section>\n\u003Csection class=\"bubble-correction\">\n\n\u003Col>\n\u003Cli>\u003Cp>Il y a \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.7278em;vertical-align:-0.0833em;\">\u003C/span>\u003Cspan class=\"mord\">6\u003C/span>\u003Cspan class=\"mspace\" style=\"margin-right:0.2222em;\">\u003C/span>\u003Cspan class=\"mbin\">+\u003C/span>\u003Cspan class=\"mspace\" style=\"margin-right:0.2222em;\">\u003C/span>\u003C/span>\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">4\u003C/span>\u003Cspan class=\"mspace\" style=\"margin-right:0.2778em;\">\u003C/span>\u003Cspan class=\"mrel\">=\u003C/span>\u003Cspan class=\"mspace\" style=\"margin-right:0.2778em;\">\u003C/span>\u003C/span>\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">10\u003C/span>\u003C/span>\u003C/span>\u003C/span> élèves inscrits en\ngymnastique.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Il y a \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">3\u003C/span>\u003C/span>\u003C/span>\u003C/span> élèves de 6ème inscrits en\nnatation.\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/section>\n\u003Ch2>Représentation de données\u003C/h2>\n\u003Ch3>Diagrammes en bâtons\u003C/h3>\n\u003Csection class=\"bubble-remember\">\n\u003Ch4>Définition\u003C/h4>\n\u003Cp>Un \u003Cstrong>diagramme en bâtons\u003C/strong> permet de comparer\nvisuellement des données.\u003C/p>\n\u003C/section>\n\u003Csection class=\"bubble-exercise\">\n\n\u003Cp>On a représenté graphiquement ci-dessous le nombre de cousin(es) de\nLéa en fonction de leur âge.\u003C/p>\n\u003Cdiv class=\"text-center\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/organisation-representation-donnees-cours/tikzpicture-1.svg\" alt=\"tikzpicture-1\">\u003C/p>\n\u003C/div>\n\u003Col>\n\u003Cli>\u003Cp>Combien Léa a-t-elle de cousin(es) qui ont \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">10\u003C/span>\u003C/span>\u003C/span>\u003C/span>\nans ? \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dotline\">\u003C/span>\u003Cspan class=\"mord\">\u003C/span>\u003C/span>\u003C/span>\u003C/span> \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dotline\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Quel âge ont le plus grand nombre de cousin(es) de Léa ? \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dotline\">\u003C/span>\u003Cspan class=\"mord\">\u003C/span>\u003C/span>\u003C/span>\u003C/span> \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dotline\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/section>\n\u003Csection class=\"bubble-correction\">\n\n\u003Col>\n\u003Cli>\u003Cp>Léa \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">2\u003C/span>\u003C/span>\u003C/span>\u003C/span> cousin(es) qui ont \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">10\u003C/span>\u003C/span>\u003C/span>\u003C/span> ans.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Le plus grand nombre de cousin(es) de Léa ont \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">2\u003C/span>\u003C/span>\u003C/span>\u003C/span> ans.\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/section>\n\u003Ch3>Diagrammes circulaires / en camembert\u003C/h3>\n\u003Csection class=\"bubble-remember\">\n\u003Ch4>Définition\u003C/h4>\n\u003Cp>Un \u003Cstrong>diagramme circulaire\u003C/strong> (ou semi-circulaires)\npermettent de mettre en évidence la répartition de données suivant\nplusieurs catégories.\u003C/p>\n\u003C/section>\n\u003Csection class=\"bubble-exercise\">\n\n\u003Cp>On a représenté graphiquement ci-dessous la répartition de garçons et\nde filles parmi les cousin(es) de Léa.\u003C/p>\n\u003Cdiv class=\"text-center\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/organisation-representation-donnees-cours/tikzpicture-2.svg\" alt=\"tikzpicture-2\">\u003C/p>\n\u003C/div>\n\u003Cp>Quelle est la proportion de filles parmi les cousins de Léa ? \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dotline\">\u003C/span>\u003Cspan class=\"mord\">\u003C/span>\u003C/span>\u003C/span>\u003C/span> \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dotline\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\n\u003C/section>\n\u003Csection class=\"bubble-correction\">\n\n\u003Cp>Léa a \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:1.1901em;vertical-align:-0.345em;\">\u003C/span>\u003Cspan class=\"mord\">\u003Cspan class=\"mopen nulldelimiter\">\u003C/span>\u003Cspan class=\"mfrac\">\u003Cspan class=\"vlist-t vlist-t2\">\u003Cspan class=\"vlist-r\">\u003Cspan class=\"vlist\" style=\"height:0.8451em;\">\u003Cspan style=\"top:-2.655em;\">\u003Cspan class=\"pstrut\" style=\"height:3em;\">\u003C/span>\u003Cspan class=\"sizing reset-size6 size3 mtight\">\u003Cspan class=\"mord mtight\">\u003Cspan class=\"mord mtight\">6\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003Cspan style=\"top:-3.23em;\">\u003Cspan class=\"pstrut\" style=\"height:3em;\">\u003C/span>\u003Cspan class=\"frac-line\" style=\"border-bottom-width:0.04em;\">\u003C/span>\u003C/span>\u003Cspan style=\"top:-3.394em;\">\u003Cspan class=\"pstrut\" style=\"height:3em;\">\u003C/span>\u003Cspan class=\"sizing reset-size6 size3 mtight\">\u003Cspan class=\"mord mtight\">\u003Cspan class=\"mord mtight\">5\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003Cspan class=\"vlist-s\">​\u003C/span>\u003C/span>\u003Cspan class=\"vlist-r\">\u003Cspan class=\"vlist\" style=\"height:0.345em;\">\u003Cspan>\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003Cspan class=\"mclose nulldelimiter\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/span> de filles parmi ses cousins et\ncousines.\u003C/p>\n\u003C/section>\n\u003Ch3>Graphique cartésien\u003C/h3>\n\u003Csection class=\"bubble-remember\">\n\u003Ch4>Définition\u003C/h4>\n\u003Cp>Un \u003Cstrong>graphique cartésien\u003C/strong> permet de montrer\nvisuellement l’évolution d’une grandeur en fonction d’une autre. Ce type\nde graphique est souvent utilisé pour étudier l’évolution d’une grandeur\ndans le temps.\u003C/p>\n\u003C/section>\n\u003Csection class=\"bubble-exercise\">\n\n\u003Cp>On a représenté graphiquement ci-dessous l’évolution de la taille\nd’un des cousins de Léa en fonction de son âge.\u003C/p>\n\u003Cdiv class=\"text-center\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/organisation-representation-donnees-cours/tikzpicture-3.svg\" alt=\"tikzpicture-3\">\u003C/p>\n\u003C/div>\n\u003Col>\n\u003Cli>\u003Cp>Quel taille faisait-il à \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">1\u003C/span>\u003C/span>\u003C/span>\u003C/span> an ? \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dotline\">\u003C/span>\u003Cspan class=\"mord\">\u003C/span>\u003C/span>\u003C/span>\u003C/span> \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dotline\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>À quel âge mesurait-il \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">95\u003C/span>\u003C/span>\u003C/span>\u003C/span> cm ? \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dotline\">\u003C/span>\u003Cspan class=\"mord\">\u003C/span>\u003C/span>\u003C/span>\u003C/span> \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dotline\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/section>\n\u003Csection class=\"bubble-correction\">\n\n\u003Col>\n\u003Cli>\u003Cp>Le cousin de Léa mesurait \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">80\u003C/span>\u003C/span>\u003C/span>\u003C/span> cm à \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">1\u003C/span>\u003C/span>\u003C/span>\u003C/span> an.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Le cousin de Léa mesurait \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">95\u003C/span>\u003C/span>\u003C/span>\u003C/span> cm à \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">4\u003C/span>\u003C/span>\u003C/span>\u003C/span> ans.\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/section>\n\u003Ch2>Production\u003C/h2>\n\u003Csection class=\"bubble-remember\">\n\u003Ch4>Propriétés\u003C/h4>\n\u003Col>\n\u003Cli>\u003Cp>Dans un diagramme en bâtons, les hauteurs des bâtons sont\nproportionnelles aux valeurs qu’elles représentent.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Dans un diagramme circulaire, les mesures des angles sont\nproportionnelles aux valeurs qu’elles représentent.\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/section>\n\u003Csection class=\"bubble-exercise\">\n\n\u003Cp>Le professeur d’arts plastiques a recensé la couleur préférée de\nchacun de ses \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">24\u003C/span>\u003C/span>\u003C/span>\u003C/span> élèves. Il a organisé ses résultats\ndans le tableau de proportionnalité suivant, et a ajouté une ligne pour\npréparer la réalisation d’un diagramme circulaire.\u003C/p>\n\u003Ctable>\n\u003Cthead>\n\u003Ctr>\n\u003Cth style=\"text-align: left;\">\u003Cstrong>Couleur préférée\u003C/strong>\u003C/th>\n\u003Cth style=\"text-align: left;\">Vert\u003C/th>\n\u003Cth style=\"text-align: left;\">Rose\u003C/th>\n\u003Cth style=\"text-align: left;\">Bleu\u003C/th>\n\u003Cth style=\"text-align: left;\">\u003Cstrong>Total\u003C/strong>\u003C/th>\n\u003C/tr>\n\u003C/thead>\n\u003Ctbody>\n\u003Ctr>\n\u003Ctd style=\"text-align: left;\">\u003Cstrong>Nombre d’élèves\u003C/strong>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">8\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">4\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">12\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.8389em;vertical-align:-0.1944em;\">\u003C/span>\u003Cspan class=\"mord\">\u003Cspan class=\"mord mathit\">24\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003C/tr>\n\u003Ctr>\n\u003Ctd style=\"text-align: left;\">\u003Cstrong>Mesure de l’angle (en\n°)\u003C/strong>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">\u003Cspan class=\"mord mathit\">360\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003C/tr>\n\u003C/tbody>\n\u003C/table>\n\u003Col>\n\u003Cli>\u003Cp>Compléter le tableau ci-dessus pour qu’il soit de\nproportionnalité.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>En l’utilisant, compléter les diagrammes en bâtons et circulaires\nsuivants.\u003C/p>\n\u003Cdiv class=\"text-center\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/organisation-representation-donnees-cours/tikzpicture-4.svg\" alt=\"tikzpicture-4\"> \u003Cimg src=\"/images/sixieme/organisation-representation-donnees-cours/tikzpicture-5.svg\" alt=\"tikzpicture-5\">\u003C/p>\n\u003C/div>\u003C/li>\n\u003C/ol>\n\u003C/section>\n\u003Csection class=\"bubble-correction\">\n\n\u003Col>\n\u003Cli>\u003Cp>Voici le tableau complété :\u003C/p>\n\u003Ctable>\n\u003Cthead>\n\u003Ctr>\n\u003Cth style=\"text-align: left;\">\u003Cstrong>Couleur préférée\u003C/strong>\u003C/th>\n\u003Cth style=\"text-align: left;\">Vert\u003C/th>\n\u003Cth style=\"text-align: left;\">Rose\u003C/th>\n\u003Cth style=\"text-align: left;\">Bleu\u003C/th>\n\u003Cth style=\"text-align: left;\">\u003Cstrong>Total\u003C/strong>\u003C/th>\n\u003C/tr>\n\u003C/thead>\n\u003Ctbody>\n\u003Ctr>\n\u003Ctd style=\"text-align: left;\">\u003Cstrong>Nombre d’élèves\u003C/strong>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">8\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">4\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">12\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.8389em;vertical-align:-0.1944em;\">\u003C/span>\u003Cspan class=\"mord\">\u003Cspan class=\"mord mathit\">24\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003C/tr>\n\u003Ctr>\n\u003Ctd style=\"text-align: left;\">\u003Cstrong>Mesure de l’angle (en\n°)\u003C/strong>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">120\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">60\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">180\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003Ctd style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">\u003Cspan class=\"mord mathit\">360\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/td>\n\u003C/tr>\n\u003C/tbody>\n\u003C/table>\u003C/li>\n\u003Cli>\u003Cp>Et voici les diagrammes complétés :\u003C/p>\n\u003Cdiv class=\"text-center\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/organisation-representation-donnees-cours/tikzpicture-6.svg\" alt=\"tikzpicture-6\"> \u003Cimg src=\"/images/sixieme/organisation-representation-donnees-cours/tikzpicture-7.svg\" alt=\"tikzpicture-7\">\u003C/p>\n\u003C/div>\u003C/li>\n\u003C/ol>\n\u003C/section>\n\u003Csection class=\"bubble-remember\">\n\u003Ch4>Méthode\u003C/h4>\n\u003Cp>Pour représenter une grandeur \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6833em;\">\u003C/span>\u003Cspan class=\"mord mathnormal\" style=\"margin-right:0.05017em;\">B\u003C/span>\u003C/span>\u003C/span>\u003C/span> en fonction d’une\ngrandeur \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6833em;\">\u003C/span>\u003Cspan class=\"mord mathnormal\">A\u003C/span>\u003C/span>\u003C/span>\u003C/span> dans un graphique cartésien, on place\n:\u003C/p>\n\u003Cul>\n\u003Cli>\u003Cp>sur l’axe horizontal, appelé \u003Cstrong>axe des abscisses\u003C/strong>,\nles valeurs de la grandeur \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6833em;\">\u003C/span>\u003Cspan class=\"mord mathnormal\">A\u003C/span>\u003C/span>\u003C/span>\u003C/span> ;\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>sur l’axe vertical, appelé \u003Cstrong>axe des ordonnées\u003C/strong>,\nles valeurs de la grandeur \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6833em;\">\u003C/span>\u003Cspan class=\"mord mathnormal\" style=\"margin-right:0.05017em;\">B\u003C/span>\u003C/span>\u003C/span>\u003C/span>.\u003C/p>\u003C/li>\n\u003C/ul>\n\u003C/section>\n\u003Csection class=\"bubble-exercise\">\n\n\u003Cp>Voici un relevé météorologique des températures de Boissy Saint-Léger\ndu 10 janvier 2023.\u003C/p>\n\u003Ctable>\n\u003Cthead>\n\u003Ctr>\n\u003Cth style=\"text-align: left;\">\u003Cstrong>Heure\u003C/strong>\u003C/th>\n\u003Cth style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6444em;\">\u003C/span>\u003Cspan class=\"mord\">0\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/th>\n\u003Cth style=\"text-align: left;\">\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" styl