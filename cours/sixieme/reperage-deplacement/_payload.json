"pstrut\" style=\"height:3em;\">\u003C/span>\u003Cspan class=\"sizing reset-size6 size3 mtight\">\u003Cspan class=\"mord mtight\">\u003Cspan class=\"mord mtight\">10\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003Cspan style=\"top:-3.23em;\">\u003Cspan class=\"pstrut\" style=\"height:3em;\">\u003C/span>\u003Cspan class=\"frac-line\" style=\"border-bottom-width:0.04em;\">\u003C/span>\u003C/span>\u003Cspan style=\"top:-3.394em;\">\u003Cspan class=\"pstrut\" style=\"height:3em;\">\u003C/span>\u003Cspan class=\"sizing reset-size6 size3 mtight\">\u003Cspan class=\"mord mtight\">\u003Cspan class=\"mord mtight\">41\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003Cspan class=\"vlist-s\">​\u003C/span>\u003C/span>\u003Cspan class=\"vlist-r\">\u003Cspan class=\"vlist\" style=\"height:0.345em;\">\u003Cspan>\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003Cspan class=\"mclose nulldelimiter\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/span>.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.8389em;vertical-align:-0.1944em;\">\u003C/span>\u003Cspan class=\"mord\">4\u003C/span>\u003Cspan class=\"mpunct\">,\u003C/span>\u003Cspan class=\"mspace\" style=\"margin-right:0.1667em;\">\u003C/span>\u003Cspan class=\"mord\">1\u003C/span>\u003C/span>\u003C/span>\u003C/span>.\u003C/p>\u003C/li>\n\u003C/ul>\u003C/li>\n\u003Cli>\u003Cdiv class=\"text-center\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/tikzpicture-3.svg\" alt=\"tikzpicture-3\">\u003C/p>\n\u003C/div>\u003C/li>\n\u003C/ol>\n\u003C/section>\n\u003Ch3>Se repérer dans un quadrillage\u003C/h3>\n\u003Csection class=\"bubble-retenir\">\n\u003Ch4>Méthode\u003C/h4>\n\u003Cp>Pour se repérer sur un quadrillage, on peut utiliser les\n\u003Cstrong>coordonnées\u003C/strong> des cases ou des nœuds.\u003C/p>\n\u003C/section>\n\u003Cdiv class=\"row\">\n\n\u003Cdiv class=\"col-12 col-lg-6\">\n\u003Csection class=\"bubble-exercice\">\n\n\u003Cdiv class=\"row\">\n\n\u003Cdiv class=\"col-12 col-lg-6\">\n\u003Cp>Déterminer l’emplacement du carré et du disque dans le quadrillage à\ncases ci-contre.\u003C/p>\n\u003Cul>\n\u003Cli>\u003Cp>\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003C/ul>\n\u003C/div>\n\u003Cdiv class=\"col-12 col-lg-6\">\n\u003Cdiv class=\"text-end\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/tikzpicture-4.svg\" alt=\"tikzpicture-4\">\u003C/p>\n\u003C/div>\n\u003C/div>\n\u003C/div>\n\u003Cdiv class=\"vertical-space\" style=\"height: 0.25cm;\">\u003C/div>\n\u003C/section>\n\u003Csection class=\"bubble-correction\">\n\n\u003Cul>\n\u003Cli>\u003Cp>\u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/tikzpicture-5.svg\" alt=\"tikzpicture-5\"> \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6833em;\">\u003C/span>\u003Cspan class=\"mord mathnormal\" style=\"margin-right:0.05017em;\">B\u003C/span>\u003Cspan class=\"mord\">4\u003C/span>\u003C/span>\u003C/span>\u003C/span>.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>\u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/tikzpicture-6.svg\" alt=\"tikzpicture-6\"> \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6833em;\">\u003C/span>\u003Cspan class=\"mord mathnormal\" style=\"margin-right:0.02778em;\">D\u003C/span>\u003Cspan class=\"mord\">3\u003C/span>\u003C/span>\u003C/span>\u003C/span>.\u003C/p>\u003C/li>\n\u003C/ul>\n\u003C/section>\n\u003C/div>\n\u003Cdiv class=\"col-12 col-lg-6\">\n\u003Csection class=\"bubble-exercice\">\n\n\u003Cdiv class=\"row\">\n\n\u003Cdiv class=\"col-12 col-lg-6\">\n\u003Cp>Déterminer l’emplacement du carré et du disque dans le quadrillage à\nnœuds ci-contre.\u003C/p>\n\u003Cul>\n\u003Cli>\u003Cp>\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003C/ul>\n\u003C/div>\n\u003Cdiv class=\"col-12 col-lg-6\">\n\u003Cdiv class=\"text-end\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/tikzpicture-7.svg\" alt=\"tikzpicture-7\">\u003C/p>\n\u003C/div>\n\u003C/div>\n\u003C/div>\n\u003C/section>\n\u003Csection class=\"bubble-correction\">\n\n\u003Cp>\u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/tikzpicture-8.svg\" alt=\"tikzpicture-8\"> \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\">\u003C/span>\u003Cspan class=\"mopen\">(\u003C/span>\u003Cspan class=\"mord\">3\u003C/span>\u003Cspan class=\"mpunct\">;\u003C/span>\u003Cspan class=\"mspace\" style=\"margin-right:0.1667em;\">\u003C/span>\u003Cspan class=\"mord\">4\u003C/span>\u003Cspan class=\"mclose\">)\u003C/span>\u003C/span>\u003C/span>\u003C/span>.\u003C/p>\n\u003Cp>\u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/tikzpicture-9.svg\" alt=\"tikzpicture-9\"> \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\">\u003C/span>\u003Cspan class=\"mopen\">(\u003C/span>\u003Cspan class=\"mord\">2\u003C/span>\u003Cspan class=\"mpunct\">;\u003C/span>\u003Cspan class=\"mspace\" style=\"margin-right:0.1667em;\">\u003C/span>\u003Cspan class=\"mord\">1\u003C/span>\u003Cspan class=\"mclose\">)\u003C/span>\u003C/span>\u003C/span>\u003C/span>.\u003C/p>\n\u003C/section>\n\u003C/div>\n\u003C/div>\n\u003Ch3>Se repérer dans un plan\u003C/h3>\n\u003Csection class=\"bubble-retenir\">\n\u003Ch4>Définition\u003C/h4>\n\u003Cdiv class=\"row\">\n\n\u003Cdiv class=\"col\" style=\"--column-size: 0.75;\">\n\u003Cp>Une \u003Cstrong>rose des vents\u003C/strong> est une figure qui indique les\nquatre points cardinaux : est, nord, ouest et sud et éventuellement les\norientations intermédiaires.\u003C/p>\n\u003Cp>Sur une carte, on peut se repérer grâce à la rose des vents, mais sur\nles cartes actuelles et les GPS, bien souvent, seule la direction du\nnord est indiquée. Elle permet à elle seule de se repérer dans le\nplan.\u003C/p>\n\u003C/div>\n\u003Cdiv class=\"col\" style=\"--column-size: 0.25;\">\n\u003Cdiv class=\"text-end\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/tikzpicture-10.svg\" alt=\"tikzpicture-10\">\u003C/p>\n\u003C/div>\n\u003C/div>\n\u003C/div>\n\u003C/section>\n\u003Csection class=\"bubble-exercice\">\n\n\u003Cdiv class=\"row\">\n\n\u003Cdiv class=\"col\" style=\"--column-size: 0.7;\">\n\u003Col>\n\u003Cli>\u003Cp>Quel bâtiment se trouve au Sud du collège Pasteur ?\u003Cbr>\n\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Que se trouve au Nord-Est de ce bâtiment ?\u003Cbr>\n\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/div>\n\u003Cdiv class=\"col\" style=\"--column-size: 0.30000000000000004;\">\n\u003Cdiv class=\"text-end\">\n\u003Cdiv class=\"framed\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/plan.png\" alt=\"plan\">\u003C/p>\n\u003C/div>\n\u003C/div>\n\u003C/div>\n\u003C/div>\n\u003C/section>\n\u003Csection class=\"bubble-correction\">\n\n\u003Col>\n\u003Cli>\u003Cp>Il s’agit de l’Église du Vieux Saint-Sauveur.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Au Nord-Est se trouve le Parc Jeux enfants.\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/section>\n\u003Ch3>Se repérer dans l’espace\u003C/h3>\n\u003Csection class=\"bubble-retenir\">\n\u003Ch4>Remarque\u003C/h4>\n\u003Cp>Dans l’espace, la vue d’un objet dépend de la position de\nl’observateur.\u003C/p>\n\u003C/section>\n\u003Csection class=\"bubble-exercice\">\n\n\u003Cdiv class=\"row\">\n\n\u003Cdiv class=\"col\" style=\"--column-size: 0.6;\">\n\u003Cp>Représenter la vue du chat (au-dessus) et celle du chien (à\ndroite).\u003C/p>\n\u003Cdiv class=\"vertical-space\" style=\"height: 6cm;\">\u003C/div>\n\u003C/div>\n\u003Cdiv class=\"col\" style=\"--column-size: 0.4;\">\n\u003Cdiv class=\"text-end\">\n\u003Cdiv class=\"framed\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/vue-espace.png\" alt=\"vue-espace\">\u003C/p>\n\u003C/div>\n\u003Cp>© Mission Indigo 6e 2021\u003C/p>\n\u003C/div>\n\u003C/div>\n\u003C/div>\n\u003C/section>\n\u003Csection class=\"bubble-correction\">\n\n\u003Cdiv class=\"text-center\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/tikzpicture-11.svg\" alt=\"tikzpicture-11\">\u003C/p>\n\u003C/div>\n\u003C/section>\n\u003Ch2>Se déplacer\u003C/h2>\n\u003Csection class=\"bubble-retenir\">\n\u003Ch4>Définition\u003C/h4>\n\u003Cp>Pour se déplacer dans le plan, il existe principalement deux langages\nde déplacement :\u003C/p>\n\u003Cul>\n\u003Cli>\u003Cp>Le \u003Cstrong>langage absolu\u003C/strong> composé des mots de\nvocabulaire du type : \u003Cq>haut\u003C/q>, \u003Cq>bas\u003C/q>, \u003Cq>droite\u003C/q> et\n\u003Cq>gauche\u003C/q>. Le déplacement se fait comme si on se plaçait en vue du\ndessus.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Le \u003Cstrong>langage relatif\u003C/strong> composé des mots de\nvocabulaire du type : \u003Cq>avancer\u003C/q>, \u003Cq>tourner à droite\u003C/q> et\n\u003Cq>tourner à gauche\u003C/q>. C’est ici le point de vue de l’observateur qui\nest adopté.\u003C/p>\u003C/li>\n\u003C/ul>\n\u003C/section>\n\u003Csection class=\"bubble-exercice\">\n\n\u003Cdiv class=\"row\">\n\n\u003Cdiv class=\"col\" style=\"--column-size: 0.22;\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/tikzpicture-12.svg\" alt=\"tikzpicture-12\">\u003C/p>\n\u003C/div>\n\u003Cdiv class=\"col\" style=\"--column-size: 0.78;\">\n\u003Col>\n\u003Cli>\u003Cp>Décrire le déplacement effectué dans le langage absolu.\u003Cbr>\n\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003Cbr>\n\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Décrire le déplacement effectué dans le langage relatif.\u003Cbr>\n\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003Cbr>\n\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0em;\">\u003C/span>\u003Cspan class=\"enclosing dots\">\u003C/span>\u003C/span>\u003C/span>\u003C/span>\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/div>\n\u003C/div>\n\u003C/section>\n\u003Csection class=\"bubble-correction\">\n\n\u003Col>\n\u003Cli>\u003Cp>Droite ; Droite ; Haut ; Droite ; Haut.\u003C/p>\u003C/li>\n\u003Cli>\u003Cp>Avancer ; Avancer ; Tourner à gauche ; Avancer ; Tourner à droite\n; Avancer ; Tourner à gauche ; Avancer.\u003C/p>\u003C/li>\n\u003C/ol>\n\u003C/section>\n\u003Csection class=\"bubble-exercice\">\n\n\u003Cp>Entourer en rouge les blocs Scratch en rapport avec le langage\nrelatif, et en bleu ceux en rapport avec le langage absolu.\u003C/p>\n\u003Cdiv class=\"text-center\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/scratch-1.svg\" alt=\"scratch-1\"> \u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/scratch-2.svg\" alt=\"scratch-2\"> \u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/scratch-3.svg\" alt=\"scratch-3\">\u003C/p>\n\u003Cp>\u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/scratch-4.svg\" alt=\"scratch-4\"> \u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/scratch-5.svg\" alt=\"scratch-5\"> \u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/scratch-6.svg\" alt=\"scratch-6\">\u003C/p>\n\u003C/div>\n\u003C/section>\n\u003Csection class=\"bubble-correction\">\n\n\u003Cp>Nous allons colorier en rouge les blocs en rapport avec le langage\nrelatif et en bleu ceux en rapport avec le langage absolu.\u003C/p>\n\u003Cdiv class=\"text-center\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/scratch-7.svg\" alt=\"scratch-7\"> \u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/scratch-8.svg\" alt=\"scratch-8\"> \u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/scratch-9.svg\" alt=\"scratch-9\">\u003C/p>\n\u003Cp>\u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/scratch-10.svg\" alt=\"scratch-10\"> \u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/scratch-11.svg\" alt=\"scratch-11\"> \u003Cimg src=\"/images/sixieme/reperage-deplacement-cours/scratch-12.svg\" alt=\"scratch-12\">\u003C/p>\n\u003C/div>\n\u003C/section>\n",[163,166,169],{"title":164,"url":165},"Activité 1","/pdf/sixieme/reperage-deplacement-activite-1.pdf",{"title":167,"url":168},"Activité 2","/pdf/sixieme/reperage-deplacement-activite-2.pdf",{"title":170,"url":171},"Activité 3","/pdf/sixieme/reperage-deplacement-activite-3.pdf",1754689054973]