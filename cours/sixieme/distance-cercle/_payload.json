an class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\">\u003C/span>\u003Cspan class=\"mopen\">(\u003C/span>\u003Cspan class=\"mord mathnormal\">d\u003C/span>\u003Cspan class=\"mclose\">)\u003C/span>\u003C/span>\u003C/span>\u003C/span> en \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6833em;\">\u003C/span>\u003Cspan class=\"mord mathnormal\" style=\"margin-right:0.08125em;\">H\u003C/span>\u003C/span>\u003C/span>\u003C/span>.\u003C/p>\n\u003C/section>\n\u003Csection class=\"bubble-exercice\">\n\n\u003Cp>Mesurer la distance entre le point \u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:0.6833em;\">\u003C/span>\u003Cspan class=\"mord mathnormal\" style=\"margin-right:0.10903em;\">M\u003C/span>\u003C/span>\u003C/span>\u003C/span> et la droite\n\u003Cspan class=\"katex\">\u003Cspan class=\"katex-html\" aria-hidden=\"true\">\u003Cspan class=\"base\">\u003Cspan class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\">\u003C/span>\u003Cspan class=\"mopen\">(\u003C/span>\u003Cspan class=\"mord mathnormal\">d\u003C/span>\u003Cspan class=\"mclose\">)\u003C/span>\u003C/span>\u003C/span>\u003C/span> dans chacun des deux cas suivants.\u003C/p>\n\u003Cdiv class=\"row\">\n\n\u003Cdiv class=\"col-12 col-lg-6\">\n\u003Cdiv class=\"text-center\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/distance-cercle-cours/tikzpicture-4.svg\" alt=\"tikzpicture-4\">\u003C/p>\n\u003C/div>\n\u003C/div>\n\u003Cdiv class=\"col-12 col-lg-6\">\n\u003Cdiv class=\"text-center\">\n\u003Cp>\u003Cimg src=\"/images/sixieme/distance-cercle-cours/tikzpicture-5.svg\" alt=\"tikzpicture-5\">\u003C/p>\n\u003C/div>\n\u003C/div>\n\u003C/div>\n\u003C/section>\n\u003Csection class=\"bubble-correction\">\n\n\u003Cdiv class=\"text-center\">\n\u003Cdiv class=\"row\">\n\n\u003Cdiv class=\"col-12 col-lg-6\">\n\u003